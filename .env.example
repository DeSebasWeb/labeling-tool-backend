# ── Directorios de almacenamiento ────────────────────────────────────────────
# PDFs subidos por el usuario
UPLOAD_DIR=./data/uploads

# PNGs renderizados por página
PAGES_DIR=./data/pages

# JSONs con metadatos de cada documento
DOCUMENTS_STORAGE_DIR=./data/documents

# JSONs con cada anotación individual
ANNOTATIONS_STORAGE_DIR=./data/annotations

# Directorio con los archivos YAML de esquemas de etiquetas
SCHEMAS_DIR=./config/schemas

# ── Renderizado PDF ───────────────────────────────────────────────────────────
# DPI de renderizado: 150 = buena calidad, 200 = alta calidad (más pesado)
RENDER_DPI=150

# ── Azure Blob Storage / Azurite ─────────────────────────────────────────────
# Azurite local (desarrollo):
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=<azurite-account-key>;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

# Azure Blob Storage real (producción):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account-name>;AccountKey=<account-key>;EndpointSuffix=core.windows.net

# ── Layout Detector (servidor GPU interno — nunca expuesto al browser) ────────
# Desarrollo local (layout-detector corriendo con CPU):
LAYOUT_DETECTOR_URL=http://localhost:8001
# Producción (nombre del servicio en la red Docker/K8s interna):
# LAYOUT_DETECTOR_URL=http://layout-detector:8000

# ── Text Detector / OCR Engine (servidor GPU interno) ────────────────────────
# Desarrollo local (text-detector corriendo con CPU):
TEXT_DETECTOR_URL=http://localhost:8002
# Produccion (nombre del servicio en la red Docker/K8s interna):
# TEXT_DETECTOR_URL=http://text-detector:8001

# ── Servidor ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173
